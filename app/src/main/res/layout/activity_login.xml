<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center"
    android:padding="28dp" android:background="@color/bg">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Syndic" android:textColor="@color/primary"
        android:textSize="34sp" android:textStyle="bold" />
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Gestion de copropriété" android:textColor="@color/muted"
        android:layout_marginBottom="28dp" />

    <EditText android:id="@+id/email" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="Email"
        android:inputType="textEmailAddress" android:padding="14dp"
        android:background="@color/surface" android:layout_marginBottom="12dp" />
    <EditText android:id="@+id/password" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="Mot de passe"
        android:inputType="textPassword" android:padding="14dp"
        android:background="@color/surface" android:layout_marginBottom="18dp" />

    <Button android:id="@+id/btn_login" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="Se connecter"
        android:backgroundTint="@color/primary" android:textColor="@color/white" />
    <TextView android:id="@+id/link_signup" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="Créer un compte"
        android:textColor="@color/accent" android:layout_marginTop="16dp" />
</LinearLayout>
